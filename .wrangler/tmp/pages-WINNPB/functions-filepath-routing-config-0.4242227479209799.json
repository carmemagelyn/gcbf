{
  "routes": [
    {
      "routePath": "/newsletter/:slug",
      "mountPath": "/newsletter",
      "method": "",
      "module": [
        "newsletter/[slug].js:onRequest"
      ]
    },
    {
      "routePath": "/api/:path*",
      "mountPath": "/api",
      "method": "",
      "module": [
        "api/[[path]].js:onRequest"
      ]
    }
  ],
  "baseURL": "/"
}